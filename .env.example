# CoClaude configuration — copy to .env (chmod 600) and fill in.

PUBLIC_URL=https://coclaude.dzsec.net
PORT=8788
DB_PATH=data/coclaude.db

# Google OAuth web client (GCP project "coclaude")
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Invite email delivery (mailcow)
SMTP_HOST=mail.dzsec.net
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=coclaude@dzsec.net

# Guards /oauth/google/start (one-time Google consent bootstrap)
ADMIN_SETUP_KEY=

# Owner identity (seeded on first boot; owner invite code printed to logs)
OWNER_EMAIL=
OWNER_NAME=Nick Dawson
OWNER_INITIALS=ND
